{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fisch-macro",
  "version": "0.1.0",
  "identifier": "com.fisch-macro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "fisch-macro",
        "width": 800,
        "height": 600
      },
      {
        "label": "overlay",
        "url": "/overlay",
        "title": "fisch-macro overlay",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximized": true,
        "visible": false,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/FemPoof/fisch-macro-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY"
    }
  }
}
